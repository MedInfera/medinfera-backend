  admissionId       String?        @map("admission_id")
  orderNumber       String         @map("order_number")
  status            LabOrderStatus @default(ORDERED)
  priority          String         @default("ROUTINE")
  clinicalInfo      String?        @map("clinical_info")
  orderedBy         String         @map("ordered_by")
  collectedBy       String?        @map("collected_by")
  processedBy       String?        @map("processed_by")
  reviewedBy        String?        @map("reviewed_by")
