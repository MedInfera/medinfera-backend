  @@map("ambulance_location_trail")
}

model Invoice {
  id             String         @id @default(uuid())
  hospitalId     String         @map("hospital_id")
  patientId      String         @map("patient_id")
  invoiceNumber  String         @map("invoice_number")
  type           InvoiceType
  status         InvoiceStatus  @default(DRAFT)
  appointmentId  String?        @map("appointment_id")
  admissionId    String?        @map("admission_id")
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount Decimal        @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountReason String?        @map("discount_reason")
  gstAmount      Decimal        @default(0) @map("gst_amount") @db.Decimal(12, 2)
  roundOff       Decimal        @default(0) @map("round_off") @db.Decimal(5, 2)
  totalAmount    Decimal        @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  dueAmount      Decimal        @default(0) @map("due_amount") @db.Decimal(12, 2)
  dueDate        DateTime?      @map("due_date") @db.Date
  notes          String?
  issuedBy       String         @map("issued_by")
  issuedAt       DateTime?      @map("issued_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  items          InvoiceItem[]
  admission      IpdAdmission?  @relation(fields: [admissionId], references: [id])
  appointment    Appointment?   @relation(fields: [appointmentId], references: [id])
  hospital       Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient        PatientProfile @relation(fields: [patientId], references: [id])
  payments       Payment[]

  @@unique([invoiceNumber, hospitalId])
  @@map("invoices")
}

model InvoiceItem {
