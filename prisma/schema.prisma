  @@map("lab_order_items")
}

model Ambulance {
  id                 String                   @id @default(uuid())
  hospitalId         String                   @map("hospital_id")
  vehicleNumber      String                   @map("vehicle_number")
  type               AmbulanceType            @default(BASIC)
  status             AmbulanceStatus          @default(AVAILABLE)
  driverId           String?                  @map("driver_id")
  gpsLatitude        Decimal?                 @map("gps_latitude") @db.Decimal(9, 6)
  gpsLongitude       Decimal?                 @map("gps_longitude") @db.Decimal(9, 6)
  lastLocationUpdate DateTime?                @map("last_location_update")
  equipmentList      String[]                 @map("equipment_list")
  registrationExpiry DateTime?                @map("registration_expiry") @db.Date
  insuranceExpiry    DateTime?                @map("insurance_expiry") @db.Date
  fitnessExpiry      DateTime?                @map("fitness_expiry") @db.Date
  isActive           Boolean                  @default(true) @map("is_active")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  dispatches         AmbulanceDispatch[]
  locationTrail      AmbulanceLocationTrail[]
  hospital           Hospital                 @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([vehicleNumber, hospitalId])
  @@map("ambulances")
}

model AmbulanceDispatch {
  id              String                   @id @default(uuid())
  hospitalId      String                   @map("hospital_id")
  ambulanceId     String                   @map("ambulance_id")
  patientId       String?                  @map("patient_id")
  status          DispatchStatus           @default(REQUESTED)
  pickupAddress   String                   @map("pickup_address")
  pickupLat       Decimal?                 @map("pickup_lat") @db.Decimal(9, 6)
  pickupLng       Decimal?                 @map("pickup_lng") @db.Decimal(9, 6)
  destination     String?
  callerName      String?                  @map("caller_name")
  callerPhone     String?                  @map("caller_phone")
  notes           String?
  requestedBy     String?                  @map("requested_by")
  dispatchedBy    String?                  @map("dispatched_by")
  requestedAt     DateTime                 @default(now()) @map("requested_at")
  dispatchedAt    DateTime?                @map("dispatched_at")
  arrivedAt       DateTime?                @map("arrived_at")
  patientLoadedAt DateTime?                @map("patient_loaded_at")
  completedAt     DateTime?                @map("completed_at")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  ambulance       Ambulance                @relation(fields: [ambulanceId], references: [id])
  hospital        Hospital                 @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient         PatientProfile?          @relation(fields: [patientId], references: [id])
  locationTrail   AmbulanceLocationTrail[]

  @@map("ambulance_dispatches")
}

model AmbulanceLocationTrail {
  id          String             @id @default(uuid())
  ambulanceId String             @map("ambulance_id")
