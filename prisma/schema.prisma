  patient              PatientProfile @relation(fields: [patientId], references: [id])

  @@map("payments")
}

model StaffPayroll {
  id          String       @id @default(uuid())
  hospitalId  String       @map("hospital_id")
  userId      String       @map("user_id")
  month       Int
  year        Int
  basicSalary Decimal      @default(0) @map("basic_salary") @db.Decimal(12, 2)
  allowances  Decimal      @default(0) @db.Decimal(12, 2)
  deductions  Decimal      @default(0) @db.Decimal(12, 2)
  netSalary   Decimal      @default(0) @map("net_salary") @db.Decimal(12, 2)
  status      PayoutStatus @default(PENDING)
  notes       String?
  processedBy String?      @map("processed_by")
  processedAt DateTime?    @map("processed_at")
  paidAt      DateTime?    @map("paid_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  payouts     Payout[]
  hospital    Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("staff_payroll")
}

model Payout {
  id              String        @id @default(uuid())
  hospitalId      String        @map("hospital_id")
  userId          String        @map("user_id")
  payrollId       String?       @map("payroll_id")
  type            PayoutType
  amount          Decimal       @db.Decimal(12, 2)
  status          PayoutStatus  @default(PENDING)
  referenceNumber String?       @map("reference_number")
